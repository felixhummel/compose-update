# ai-jail sandbox configuration
# https://github.com/akitaonrails/ai-jail
# Edit freely. Regenerate with: ai-jail --clean --init

command = [
    "pi",
    "-c",
]
rw_maps = [
    "/home/felix/.pi/",
    "/home/felix/.local/share/nvim",
    "/home/felix/.vim/undodir",
    "/home/felix/ai",
    "/var/run/postgresql",
    "/run/user/1337/tmux-tmp",
]
ro_maps = [
    "/home/felix/.bashrc",
    "/home/felix/.odoorc",
    "/home/felix/.ripgreprc",
    "/home/felix/.tmux.conf",
    "/home/felix/.tmux/",
    "/home/felix/bin",
    "/home/felix/github",
    "/tmp/tdrop_felix_:0.0",
]
hide_dotdirs = []
mask = []
no_docker = true
no_mise = false
allow_tcp_ports = []
